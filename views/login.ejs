<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <link rel="stylesheet" href="/css/auth.css" />

</head>
<body>
<div class="auth-page">
  <a href="/auth" class="auth-back-link">
    <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back
  </a>
  <div class="login-card">
    <div class="login-header">
      <div class="auth-logo" style="margin-bottom:20px;">
        <div class="auth-logo-icon">
          <i data-lucide="cpu" style="width:22px;height:22px;stroke:white;stroke-width:2;"></i>
        </div>
        <span class="auth-logo-name">Factory Brain</span>
      </div>
      <h1 class="login-title">Welcome back</h1>
      <p class="login-sub">Log in to your production planning workspace</p>
    </div>



    <!-- ── Login Form ── -->
    <form class="login-form" id="loginForm" onsubmit="handleLogin(event)">
      <div class="form-group">
        <label class="form-label" for="login-username">Username or Email</label>
        <div style="position:relative;">
          <i data-lucide="at-sign" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:#94A3B8;pointer-events:none;"></i>
          <input class="form-input" type="text" id="login-username" name="username" placeholder="your_username" autocomplete="username" required style="padding-left:36px;" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="login-password" style="display:flex;justify-content:space-between;align-items:center;">
          Password
          <a href="#" class="forgot-link" style="display:flex;align-items:center;gap:4px;">
            <i data-lucide="key-round" style="width:12px;height:12px;"></i> Forgot password?
          </a>
        </label>
        <div class="password-wrapper">
          <input class="form-input" type="password" id="login-password" name="password" placeholder="••••••••" autocomplete="current-password" required />
          <button class="password-toggle" onclick="togglePwd('login-password',this)" type="button">
            <i data-lucide="eye" style="width:15px;height:15px;"></i>
          </button>
        </div>
      </div>

      <button class="btn btn-primary" type="submit" id="loginBtn" style="width:100%;justify-content:center;padding:13px 20px;font-size:15px;display:flex;align-items:center;gap:8px;">
        <i data-lucide="log-in" style="width:16px;height:16px;"></i>
        Log in to Factory Brain
      </button>
    </form>

    <div class="login-footer">
      Don't have an account? <a href="/signup">Create one free →</a>
    </div>
  </div>
</div>

<script src="/js/auth.js"></script>
<script>
  lucide.createIcons();
</script>
</body>
</html>
