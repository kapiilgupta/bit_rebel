# Factory Brain — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas — get from https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/YOUR_DB_NAME?retryWrites=true&w=majority

# JWT Auth (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE=604800000

# CORS (leave blank for localhost)
CLIENT_ORIGIN=
